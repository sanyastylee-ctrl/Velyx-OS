[Unit]
Description=Velyx OS Diagnostics Service
PartOf=velyx-session.target
After=graphical-session-pre.target dbus.service

[Service]
Type=simple
Environment=VELYX_USER_ID=%u
Environment=HOME=%h
ExecStart=/usr/bin/velyx-diagnostics-service
Restart=on-failure
RestartSec=1

[Install]
WantedBy=velyx-session.target
