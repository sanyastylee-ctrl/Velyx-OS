[Unit]
Description=Velyx OS Launcher Service
PartOf=velyx-session.target
After=graphical-session-pre.target dbus.service

[Service]
Type=simple
EnvironmentFile=-%h/.config/velyx/velyx.env
Environment=VELYX_USER_ID=%u
Environment=HOME=%h
ExecStart=/usr/bin/velyx-launcher-service
Restart=always
RestartSec=1

[Install]
WantedBy=velyx-session.target
