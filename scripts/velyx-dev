#!/usr/bin/env python3
import difflib
import json
import os
import re
import shutil
import subprocess
import struct
import sys
import uuid
from datetime import datetime, timezone
from pathlib import Path
from typing import Any


def now_iso() -> str:
    return datetime.now(timezone.utc).replace(microsecond=0).isoformat().replace("+00:00", "Z")


def load_env_file() -> dict[str, str]:
    env_path = Path(os.environ.get("XDG_CONFIG_HOME", str(Path.home() / ".config"))) / "velyx" / "velyx.env"
    values: dict[str, str] = {}
    if env_path.exists():
        for line in env_path.read_text(encoding="utf-8").splitlines():
            line = line.strip()
            if not line or line.startswith("#") or "=" not in line:
                continue
            key, value = line.split("=", 1)
            values[key.strip()] = value.strip()
    return values


ENV = load_env_file()
ROOT_DIR = Path(__file__).resolve().parent.parent
STATE_DIR = Path(os.environ.get("VELYX_STATE_DIR") or ENV.get("VELYX_STATE_DIR") or (Path.home() / ".velyx"))
DEV_MODE_FILE = STATE_DIR / "dev_mode.json"
DEV_MODE_CONFIG_FILE = STATE_DIR / "dev_mode_config.json"
DEV_HISTORY_FILE = STATE_DIR / "dev_history.json"
DEV_LOG = STATE_DIR / "dev_mode.log"
DEV_AGENT_LOG = STATE_DIR / "dev_agent.log"
OVERLAY_ROOT = STATE_DIR / "dev_overlay"
OVERLAY_HISTORY = STATE_DIR / "dev_overlay_history"
OVERLAY_SNAPSHOTS = STATE_DIR / "dev_overlay_snapshots"
DEV_PATCHES_ROOT = STATE_DIR / "dev_patches"
SCREENSHOT_ROOT = STATE_DIR / "dev_screenshots"
BASE_SHELL_QML = ROOT_DIR / "apps" / "shell" / "qml"
BASE_SHELL_SRC = ROOT_DIR / "apps" / "shell" / "src"
BASE_THEME = ROOT_DIR / "packages" / "design-system" / "qml" / "Velyx" / "DesignSystem" / "Theme.qml"
ALLOWED_ROOTS = {
    "apps/shell/qml": BASE_SHELL_QML,
    "apps/shell/src": BASE_SHELL_SRC,
    "packages/design-system/qml/Velyx/DesignSystem/Theme.qml": BASE_THEME,
}
LIVE_SCOPE_PREFIXES = [
    "apps/shell/qml/",
    "apps/shell/src/",
    "packages/design-system/qml/Velyx/DesignSystem/Theme.qml",
]
STAGED_SCOPE_PREFIXES = [
    "services/",
    "scripts/velyx-assistant",
    "scripts/velyx-ai",
    "scripts/velyx-agent",
    "scripts/velyx-intent",
    "scripts/velyx-rule",
    "scripts/velyx-model",
    "scripts/velyx-firstboot",
    "scripts/velyx-installer",
    "scripts/velyx-diagnostics",
    "apps/shell/qml/",
    "apps/shell/src/",
    "docs/",
]
MAX_HISTORY = 12
MAX_VISUAL_ITERATIONS = 2


class DevModeError(RuntimeError):
    pass


def read_json(path: Path, default: Any) -> Any:
    if not path.exists():
        return default
    try:
        return json.loads(path.read_text(encoding="utf-8"))
    except Exception:
        return default


def write_json(path: Path, payload: dict[str, Any]) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    path.write_text(json.dumps(payload, ensure_ascii=False, indent=2), encoding="utf-8")


def print_json(payload: Any) -> None:
    print(json.dumps(payload, ensure_ascii=False, indent=2))


def log_event(event: str, status: str, detail: str = "") -> None:
    STATE_DIR.mkdir(parents=True, exist_ok=True)
    with DEV_LOG.open("a", encoding="utf-8") as handle:
        handle.write(f"{now_iso()} event={event} status={status} {detail}\n")


def log_agent_event(event: str, status: str, detail: str = "") -> None:
    STATE_DIR.mkdir(parents=True, exist_ok=True)
    with DEV_AGENT_LOG.open("a", encoding="utf-8") as handle:
        handle.write(f"{now_iso()} event={event} status={status} {detail}\n")


def default_config() -> dict[str, Any]:
    return {
        "enabled": False,
        "mode": "disabled",
        "allowed_scopes": LIVE_SCOPE_PREFIXES,
        "auto_apply_live_changes": False,
        "max_files_per_change": 4,
        "allow_system_staging": False,
        "allow_reboot_required_changes": False,
        "visual_feedback_enabled": True,
        "keep_patch_history": True,
    }


def ensure_config() -> dict[str, Any]:
    config = read_json(DEV_MODE_CONFIG_FILE, {})
    defaults = default_config()
    changed = False
    for key, value in defaults.items():
        if key not in config:
            config[key] = value
            changed = True
    if config.get("mode") == "disabled":
        config["enabled"] = False
    if changed or not DEV_MODE_CONFIG_FILE.exists():
        write_json(DEV_MODE_CONFIG_FILE, config)
    return config


def save_config(config: dict[str, Any]) -> None:
    write_json(DEV_MODE_CONFIG_FILE, config)


def default_history() -> dict[str, Any]:
    return {"changes": []}


def ensure_history() -> dict[str, Any]:
    history = read_json(DEV_HISTORY_FILE, {})
    if "changes" not in history or not isinstance(history.get("changes"), list):
        history = default_history()
        write_json(DEV_HISTORY_FILE, history)
    return history


def save_history(history: dict[str, Any]) -> None:
    write_json(DEV_HISTORY_FILE, history)


def default_state() -> dict[str, Any]:
    config = ensure_config()
    history = ensure_history()
    return {
        "enabled": bool(config.get("enabled", False)),
        "dev_agent_mode": config.get("mode", "disabled"),
        "overlay_root": str(OVERLAY_ROOT),
        "source_root": str(ROOT_DIR),
        "allowed_roots": list(config.get("allowed_scopes", LIVE_SCOPE_PREFIXES)),
        "visual_feedback_active": bool(config.get("visual_feedback_enabled", True)),
        "auto_refine": False,
        "max_visual_iterations": MAX_VISUAL_ITERATIONS,
        "last_change_id": "",
        "last_change_summary": "",
        "last_change_files": [],
        "last_visual_request": "",
        "last_visual_status": "",
        "last_visual_summary": "",
        "last_visual_recommendation": "",
        "pending_refinement_request": "",
        "last_visual_iteration": 0,
        "last_screenshot": "",
        "previous_screenshot": "",
        "last_comparison": {},
        "history": [],
        "dev_agent_last_request": "",
        "dev_agent_last_plan_summary": "",
        "dev_agent_change_class": "",
        "dev_agent_apply_strategy": "",
        "dev_agent_scope": "",
        "dev_agent_affected_files": [],
        "dev_agent_validation_status": "",
        "dev_agent_approval_level": "",
        "dev_agent_last_change_id": "",
        "dev_agent_history_size": len(history.get("changes", [])),
        "updated_at": now_iso(),
    }


def ensure_state() -> dict[str, Any]:
    state = read_json(DEV_MODE_FILE, {})
    defaults = default_state()
    changed = False
    for key, value in defaults.items():
        if key not in state:
            state[key] = value
            changed = True
    config = ensure_config()
    history = ensure_history()
    state["enabled"] = bool(config.get("enabled", False))
    state["dev_agent_mode"] = config.get("mode", "disabled")
    state["allowed_roots"] = list(config.get("allowed_scopes", LIVE_SCOPE_PREFIXES))
    state["visual_feedback_active"] = bool(config.get("visual_feedback_enabled", True))
    state["dev_agent_history_size"] = len(history.get("changes", []))
    if changed or not DEV_MODE_FILE.exists():
        write_json(DEV_MODE_FILE, state)
    return state


def save_state(state: dict[str, Any]) -> None:
    state["updated_at"] = now_iso()
    write_json(DEV_MODE_FILE, state)


def relative_target(path_text: str) -> str:
    candidate = Path(path_text)
    normalized = candidate.as_posix().lstrip("/")
    if normalized in ALLOWED_ROOTS:
        return normalized
    if normalized.startswith("apps/shell/qml/"):
        return normalized
    if normalized.startswith("apps/shell/src/"):
        return normalized
    if normalized == "packages/design-system/qml/Velyx/DesignSystem/Theme.qml":
        return normalized
    raise DevModeError(f"Path is outside dev mode scope: {path_text}")


def base_path_for(relative_path: str) -> Path:
    normalized = relative_target(relative_path)
    return ROOT_DIR / Path(normalized)


def overlay_path_for(relative_path: str) -> Path:
    normalized = relative_target(relative_path)
    return OVERLAY_ROOT / Path(normalized)


def seed_overlay() -> None:
    (OVERLAY_ROOT / "apps" / "shell" / "qml").mkdir(parents=True, exist_ok=True)
    for source in BASE_SHELL_QML.glob("*.qml"):
        target = OVERLAY_ROOT / "apps" / "shell" / "qml" / source.name
        if not target.exists():
            shutil.copy2(source, target)
    theme_target = OVERLAY_ROOT / "packages" / "design-system" / "qml" / "Velyx" / "DesignSystem" / "Theme.qml"
    theme_target.parent.mkdir(parents=True, exist_ok=True)
    if BASE_THEME.exists() and not theme_target.exists():
        shutil.copy2(BASE_THEME, theme_target)


def mode_to_config(mode: str) -> dict[str, Any]:
    config = ensure_config()
    if mode == "disabled":
        config["enabled"] = False
        config["mode"] = "disabled"
        config["allowed_scopes"] = LIVE_SCOPE_PREFIXES
        config["allow_system_staging"] = False
        config["allow_reboot_required_changes"] = False
    elif mode == "ui_live_only":
        config["enabled"] = True
        config["mode"] = "ui_live_only"
        config["allowed_scopes"] = LIVE_SCOPE_PREFIXES
        config["allow_system_staging"] = False
        config["allow_reboot_required_changes"] = False
    elif mode == "full_dev":
        config["enabled"] = True
        config["mode"] = "full_dev"
        config["allowed_scopes"] = LIVE_SCOPE_PREFIXES + [scope for scope in STAGED_SCOPE_PREFIXES if scope not in LIVE_SCOPE_PREFIXES]
        config["allow_system_staging"] = True
        config["allow_reboot_required_changes"] = True
    else:
        raise DevModeError("Mode must be disabled, ui_live_only, or full_dev")
    return config


def set_dev_agent_mode(mode: str) -> dict[str, Any]:
    config = mode_to_config(mode)
    save_config(config)
    if config["enabled"]:
        seed_overlay()
    state = ensure_state()
    state["enabled"] = bool(config["enabled"])
    state["dev_agent_mode"] = config["mode"]
    state["allowed_roots"] = list(config.get("allowed_scopes", []))
    save_state(state)
    log_event("dev_mode_mode_changed", "ok", f"mode={mode}")
    log_agent_event("dev_agent_mode_changed", "ok", f"mode={mode}")
    return {
        "enabled": bool(config["enabled"]),
        "mode": config["mode"],
        "summary": f"Dev Agent mode set to {config['mode']}.",
    }


def enable_dev_mode() -> dict[str, Any]:
    config = ensure_config()
    target_mode = config.get("mode", "disabled")
    if target_mode == "disabled":
        target_mode = "ui_live_only"
    result = set_dev_agent_mode(target_mode)
    result["overlay_root"] = str(OVERLAY_ROOT)
    result["summary"] = "Dev Mode enabled. Shell will prefer the live overlay on restart."
    return result


def disable_dev_mode() -> dict[str, Any]:
    result = set_dev_agent_mode("disabled")
    result["overlay_root"] = str(OVERLAY_ROOT)
    result["summary"] = "Dev Mode disabled. Shell will load the installed UI again on next restart."
    return result


def status() -> dict[str, Any]:
    state = ensure_state()
    config = ensure_config()
    history = ensure_history()
    return {
        "enabled": bool(state.get("enabled", False)),
        "mode": config.get("mode", "disabled"),
        "overlay_root": str(OVERLAY_ROOT),
        "visual_feedback_active": bool(state.get("visual_feedback_active", True)),
        "auto_refine": bool(state.get("auto_refine", False)),
        "history_entries": len(history.get("changes", [])),
        "last_change_id": state.get("last_change_id", ""),
        "last_change_summary": state.get("last_change_summary", ""),
        "last_change_files": state.get("last_change_files", []),
        "last_screenshot": state.get("last_screenshot", ""),
        "previous_screenshot": state.get("previous_screenshot", ""),
        "last_visual_summary": state.get("last_visual_summary", ""),
        "last_visual_recommendation": state.get("last_visual_recommendation", ""),
        "pending_refinement_request": state.get("pending_refinement_request", ""),
        "dev_agent_last_request": state.get("dev_agent_last_request", ""),
        "dev_agent_last_plan_summary": state.get("dev_agent_last_plan_summary", ""),
        "dev_agent_change_class": state.get("dev_agent_change_class", ""),
        "dev_agent_apply_strategy": state.get("dev_agent_apply_strategy", ""),
        "dev_agent_scope": state.get("dev_agent_scope", ""),
        "dev_agent_affected_files": state.get("dev_agent_affected_files", []),
        "dev_agent_validation_status": state.get("dev_agent_validation_status", ""),
        "dev_agent_approval_level": state.get("dev_agent_approval_level", ""),
        "config": config,
    }


def list_ui_files(scope: str = "all") -> list[dict[str, str]]:
    entries: list[dict[str, str]] = []
    scopes = {
        "qml": ["apps/shell/qml"],
        "src": ["apps/shell/src"],
        "design": ["packages/design-system/qml/Velyx/DesignSystem/Theme.qml"],
        "all": list(ALLOWED_ROOTS.keys()),
    }
    targets = scopes.get(scope, scopes["all"])
    for relative in targets:
        base = base_path_for(relative)
        if base.is_file():
            entries.append({"path": relative, "kind": "file"})
            continue
        for file_path in sorted(base.rglob("*")):
            if file_path.is_file():
                entries.append({"path": str(file_path.relative_to(ROOT_DIR)).replace("\\", "/"), "kind": "file"})
    return entries


def list_system_modules() -> list[dict[str, str]]:
    entries: list[dict[str, str]] = []
    for prefix in ["services", "scripts", "docs", "apps/shell/qml", "apps/shell/src"]:
        root = ROOT_DIR / prefix
        if root.exists():
            entries.append({"path": prefix, "kind": "module"})
    return entries


def validate_code_scope(relative_path: str) -> bool:
    normalized = relative_path.replace("\\", "/").lstrip("/")
    config = ensure_config()
    return any(
        normalized == scope.rstrip("/") or normalized.startswith(scope)
        for scope in config.get("allowed_scopes", [])
    )


def read_dev_file(path_text: str) -> dict[str, Any]:
    relative = path_text.replace("\\", "/").lstrip("/")
    if not validate_code_scope(relative):
        raise DevModeError(f"Path is outside dev agent scope: {relative}")
    path = ROOT_DIR / relative
    if not path.exists():
        raise DevModeError(f"Dev file not found: {relative}")
    return {
        "path": relative,
        "content": path.read_text(encoding="utf-8", errors="replace"),
    }


def read_ui_file(path_text: str) -> dict[str, Any]:
    relative = relative_target(path_text)
    overlay = overlay_path_for(relative)
    base = base_path_for(relative)
    path = overlay if overlay.exists() else base
    if not path.exists():
        raise DevModeError(f"UI file not found: {relative}")
    return {
        "path": relative,
        "source": "overlay" if overlay.exists() else "base",
        "content": path.read_text(encoding="utf-8"),
    }


def search_ui_component(query: str) -> list[dict[str, Any]]:
    needle = query.strip().lower()
    if not needle:
        raise DevModeError("Missing component query")
    results: list[dict[str, Any]] = []
    for entry in list_ui_files("all"):
        relative = entry["path"]
        path = overlay_path_for(relative)
        if not path.exists():
            path = base_path_for(relative)
        text = path.read_text(encoding="utf-8")
        for line_number, line in enumerate(text.splitlines(), start=1):
            if needle in line.lower():
                results.append(
                    {
                        "path": relative,
                        "line": line_number,
                        "preview": line.strip(),
                    }
                )
                if len(results) >= 20:
                    return results
    return results


def search_code(query: str) -> list[dict[str, Any]]:
    needle = query.strip().lower()
    if not needle:
        raise DevModeError("Missing code query")
    results: list[dict[str, Any]] = []
    for root_name in ["apps", "services", "scripts", "docs", "packages"]:
        root = ROOT_DIR / root_name
        if not root.exists():
            continue
        for path in root.rglob("*"):
            if not path.is_file():
                continue
            if path.suffix.lower() not in {".qml", ".cpp", ".h", ".py", ".rs", ".json", ".sh", ".md", ""}:
                continue
            try:
                text = path.read_text(encoding="utf-8", errors="replace")
            except Exception:
                continue
            for line_number, line in enumerate(text.splitlines(), start=1):
                if needle in line.lower():
                    results.append(
                        {
                            "path": str(path.relative_to(ROOT_DIR)).replace("\\", "/"),
                            "line": line_number,
                            "preview": line.strip(),
                        }
                    )
                    if len(results) >= 30:
                        return results
    return results


def create_snapshot(summary: str = "manual snapshot") -> dict[str, Any]:
    state = ensure_state()
    snapshot_id = f"{datetime.now(timezone.utc).strftime('%Y%m%dT%H%M%SZ')}-{uuid.uuid4().hex[:6]}"
    destination = OVERLAY_SNAPSHOTS / snapshot_id
    if OVERLAY_ROOT.exists():
        shutil.copytree(OVERLAY_ROOT, destination, dirs_exist_ok=True)
    else:
        destination.mkdir(parents=True, exist_ok=True)
    state["last_snapshot_id"] = snapshot_id
    save_state(state)
    log_event("dev_snapshot_created", "ok", f"id={snapshot_id} summary={summary}")
    return {"snapshot_id": snapshot_id, "path": str(destination), "summary": summary}


def set_auto_refine(enabled: bool) -> dict[str, Any]:
    state = ensure_state()
    state["auto_refine"] = enabled
    save_state(state)
    log_event("dev_auto_refine_changed", "ok", f"enabled={enabled}")
    return {
        "auto_refine": enabled,
        "summary": "Auto refine enabled." if enabled else "Auto refine disabled.",
    }


def ensure_enabled() -> dict[str, Any]:
    state = ensure_state()
    if not state.get("enabled", False):
        raise DevModeError("Dev Mode is disabled. Run 'velyx-dev enable' first.")
    seed_overlay()
    return state


def approval_level_for(change_class: str, files: list[str]) -> str:
    if change_class == "ui_live" and len(files) <= 1 and ensure_config().get("auto_apply_live_changes", False):
        return "auto_apply_allowed"
    if change_class == "forbidden":
        return "forbidden"
    return "explicit_approval_required"


def classify_change(request: str) -> dict[str, Any]:
    lowered = request.lower()
    config = ensure_config()
    mode = config.get("mode", "disabled")
    if any(token in lowered for token in ["root ", "system32", "/etc/", "registry", "secret", "password", "token", "ssh key", "rm -rf"]):
        return {
            "change_class": "forbidden",
            "apply_strategy": "deny",
            "scope": "forbidden",
            "reason": "The request targets files or actions outside the allowed development boundaries.",
            "allowed": False,
        }

    ui_tokens = ["кноп", "button", "panel", "панель", "spacing", "gap", "card", "layout", "qml", "compact"]
    shell_logic_tokens = ["assistant panel", "control center", "sidebar", "onboarding flow", "first boot", "installer ui", "panel behavior"]
    noncritical_tokens = ["intent", "tool for assistant", "assistant tool", "routing", "model", "automation", "rules", "diagnostics", "spaces"]
    critical_tokens = ["launcher", "session-manager", "update", "recovery", "install", "bootstrap", "permissions", "security core"]

    if any(token in lowered for token in critical_tokens):
        change_class = "runtime_critical"
    elif any(token in lowered for token in noncritical_tokens):
        change_class = "runtime_noncritical"
    elif any(token in lowered for token in shell_logic_tokens):
        change_class = "shell_logic"
    elif any(token in lowered for token in ui_tokens):
        change_class = "ui_live"
    else:
        change_class = "shell_logic"

    if mode == "disabled":
        return {
            "change_class": change_class,
            "apply_strategy": "deny",
            "scope": "disabled",
            "reason": "Dev Agent is disabled.",
            "allowed": False,
        }

    if change_class == "ui_live":
        return {
            "change_class": change_class,
            "apply_strategy": "live_apply",
            "scope": "safe_live_scopes",
            "reason": "This is a visual shell/UI tweak that can be applied through the live overlay.",
            "allowed": True,
        }
    if change_class == "shell_logic":
        return {
            "change_class": change_class,
            "apply_strategy": "live_apply" if mode == "ui_live_only" else "staged_update",
            "scope": "shell_logic",
            "reason": "This change touches shell behavior. It stays live only when safely contained to shell files.",
            "allowed": True,
        }
    if change_class == "runtime_noncritical":
        allowed = mode == "full_dev" and config.get("allow_system_staging", False)
        return {
            "change_class": change_class,
            "apply_strategy": "staged_update" if allowed else "deny",
            "scope": "staged_update_scopes",
            "reason": "This is a non-critical runtime change and should go through the staged update path.",
            "allowed": allowed,
        }
    if change_class == "runtime_critical":
        allowed = mode == "full_dev" and config.get("allow_reboot_required_changes", False)
        return {
            "change_class": change_class,
            "apply_strategy": "reboot_required" if allowed else "deny",
            "scope": "critical_runtime_scopes",
            "reason": "This change touches critical runtime paths and should be treated as reboot-required.",
            "allowed": allowed,
        }
    return {
        "change_class": "forbidden",
        "apply_strategy": "deny",
        "scope": "forbidden",
        "reason": "The request could not be mapped to a safe development change class.",
        "allowed": False,
    }


def list_qml_components() -> list[str]:
    return sorted(path.name for path in BASE_SHELL_QML.glob("*.qml"))


def resolve_dev_files(request: str, classification: dict[str, Any]) -> list[str]:
    lowered = request.lower()
    change_class = classification["change_class"]
    if change_class in {"ui_live", "shell_logic"}:
        if "assistant" in lowered or "button" in lowered or "кноп" in lowered:
            return ["apps/shell/qml/AssistantPanel.qml"]
        if "space" in lowered or "spaces" in lowered:
            return ["apps/shell/qml/SpaceOverviewPanel.qml", "apps/shell/qml/Main.qml"]
        if "control center" in lowered:
            return ["apps/shell/qml/Main.qml", "apps/shell/qml/DetailsPanel.qml"]
        if "first boot" in lowered or "onboarding" in lowered:
            return ["apps/shell/qml/FirstBootOverlay.qml"]
        return ["apps/shell/qml/Main.qml"]
    if change_class == "runtime_noncritical":
        if "intent" in lowered:
            return ["scripts/velyx-intent", "docs/intents-system.md"]
        if "tool" in lowered or "assistant" in lowered:
            return ["scripts/velyx-assistant", "docs/assistant.md"]
        if "routing" in lowered or "model" in lowered:
            return ["scripts/velyx-model", "scripts/velyx-ai", "docs/local-model-runtime.md"]
        if "diagnostic" in lowered or "recovery ux" in lowered:
            return ["scripts/velyx-diagnostics", "apps/shell/qml/DiagnosticsPanel.qml"]
        return ["scripts/velyx-assistant"]
    if change_class == "runtime_critical":
        if "recovery" in lowered:
            return ["scripts/velyx-recovery", "scripts/velyx-update"]
        if "install" in lowered or "bootstrap" in lowered:
            return ["scripts/velyx-install.sh", "scripts/velyx-installer"]
        if "permissions" in lowered:
            return ["services/permissions-service", "apps/shell/src/permissionclient.cpp"]
        return ["scripts/velyx-update", "scripts/velyx-install.sh"]
    return []


def add_compact_button_markers(content: str) -> str:
    if "// dev-mode compact-button" in content:
        return content
    pattern = re.compile(r"(?P<indent>\s*)Button\s*\{\n", re.MULTILINE)

    def replacer(match: re.Match[str]) -> str:
        indent = match.group("indent")
        return (
            f"{indent}Button {{\n"
            f"{indent}    // dev-mode compact-button\n"
            f"{indent}    implicitHeight: 34\n"
            f"{indent}    padding: Theme.space2\n"
        )

    return pattern.sub(replacer, content)


def tighten_assistant_spacing(content: str) -> str:
    if "// dev-mode compact-spacing" in content:
        return content
    updated = content.replace("spacing: 8", "spacing: 6")
    if updated == content:
        return content
    marker = "Flow {\n            Layout.fillWidth: true\n            spacing: 6"
    return updated.replace(marker, "Flow {\n            Layout.fillWidth: true\n            // dev-mode compact-spacing\n            spacing: 6", 1)


def insert_button_after(content: str, neighbor: str, label: str) -> str:
    marker = f'text: "{neighbor}"'
    new_button = (
        '            Button {\n'
        f'                text: "{label}"\n'
        '                // dev-mode generated action\n'
        '                onClicked: root.permissionClient.askAssistant("Summarize the current system state")\n'
        '            }\n'
    )
    if label in content:
        return content
    lines = content.splitlines()
    for index, line in enumerate(lines):
        if marker in line:
            insert_at = index + 1
            while insert_at < len(lines) and lines[insert_at].strip() != "}":
                insert_at += 1
            if insert_at < len(lines):
                lines.insert(insert_at + 1, new_button.rstrip("\n"))
                return "\n".join(lines) + "\n"
    flow_anchor = 'Button { text: "Create Note"; onClicked: root.permissionClient.askAssistant("Create a note in Documents as markdown") }'
    if flow_anchor in content:
        return content.replace(flow_anchor, flow_anchor + "\n" + new_button.rstrip("\n")) + "\n"
    raise DevModeError("Could not find a suitable button row for insertion")


def widen_right_rail(content: str) -> str:
    if "Layout.preferredWidth: 430" in content:
        return content
    return content.replace("Layout.preferredWidth: 390", "Layout.preferredWidth: 430", 1)


def insert_default_intent(content: str, intent_id: str, display_name: str, target_space: str = "general") -> str:
    if f'"intent_id": "{intent_id}"' in content:
        return content
    timestamp = now_iso()
    block = (
        "            {\n"
        f'                "intent_id": "{intent_id}",\n'
        f'                "display_name": "{display_name}",\n'
        f'                "description": "Added by Velyx Dev Agent for {display_name}.",\n'
        f'                "target_space": "{target_space}",\n'
        '                "actions": [],\n'
        '                "auto_focus": True,\n'
        '                "ensure_apps": True,\n'
        '                "restart_policy": "space_default",\n'
        '                "status": "enabled",\n'
        f'                "created_at": "{timestamp}",\n'
        f'                "updated_at": "{timestamp}",\n'
        '                "source": "system",\n'
        "            },\n"
    )
    needle = '        "intents": [\n'
    if needle not in content:
        raise DevModeError("Could not find the default intents list in velyx-intent")
    return content.replace(needle, needle + block, 1)


def build_changes(request: str, classification: dict[str, Any]) -> list[dict[str, Any]]:
    lowered = request.lower()
    change_class = classification["change_class"]
    changes: list[dict[str, Any]] = []
    if change_class in {"ui_live", "shell_logic"}:
        if any(token in lowered for token in ["кноп", "button"]) and any(token in lowered for token in ["мень", "small", "compact", "компакт"]):
            relative = "apps/shell/qml/AssistantPanel.qml"
            current = read_ui_file(relative)["content"]
            updated = add_compact_button_markers(current)
            changes.append({"path": relative, "summary": "Made assistant action buttons more compact.", "before": current, "after": updated, "target": "overlay"})
            return changes

        if any(token in lowered for token in ["spacing", "gap", "отступ", "distance", "tighten", "compact the spacing", "разреж", "плотн"]):
            relative = "apps/shell/qml/AssistantPanel.qml"
            current = read_ui_file(relative)["content"]
            updated = tighten_assistant_spacing(current)
            changes.append({"path": relative, "summary": "Tightened the spacing in the assistant action area.", "before": current, "after": updated, "target": "overlay"})
            return changes

        if any(token in lowered for token in ["панель", "panel"]) and any(token in lowered for token in ["вправ", "right", "шир", "wider"]):
            relative = "apps/shell/qml/Main.qml"
            current = read_ui_file(relative)["content"]
            updated = widen_right_rail(current)
            changes.append({"path": relative, "summary": "Shifted emphasis to the right rail by widening it.", "before": current, "after": updated, "target": "overlay"})
            return changes

        if any(token in lowered for token in ["добав", "add"]) and any(token in lowered for token in ["кноп", "button"]):
            relative = "apps/shell/qml/AssistantPanel.qml"
            current = read_ui_file(relative)["content"]
            match = re.search(r'["“](.+?)["”]', request)
            label = match.group(1).strip() if match else "Quick action"
            neighbor = "Create Note"
            if "browser" in lowered or "брауз" in lowered:
                neighbor = "Open Browser"
            elif "development" in lowered or "dev" in lowered:
                neighbor = "Development"
            updated = insert_button_after(current, neighbor, label)
            changes.append({"path": relative, "summary": f'Added a new quick action button "{label}".', "before": current, "after": updated, "target": "overlay"})
            return changes

        raise DevModeError("UI request is outside the current dev-mode skill set. Supported examples: compact buttons, move panel right, add a quick action button.")

    if change_class == "runtime_noncritical":
        if "intent" in lowered and any(token in lowered for token in ["добав", "add", "new"]):
            relative = "scripts/velyx-intent"
            current = (ROOT_DIR / relative).read_text(encoding="utf-8")
            quoted = re.search(r'["“](.+?)["”]', request)
            display_name = quoted.group(1).strip() if quoted else "Focus Session"
            intent_id = re.sub(r"[^a-z0-9]+", "_", display_name.lower()).strip("_") or "focus_session"
            target_space = "development" if "dev" in lowered or "разработ" in lowered else "general"
            updated = insert_default_intent(current, intent_id, display_name, target_space=target_space)
            changes.append({"path": relative, "summary": f'Added a new default intent "{intent_id}" to the intent registry seed.', "before": current, "after": updated, "target": "repo"})
            return changes
        raise DevModeError("This system development request was classified and scoped, but no safe patch template exists yet. Export a patch bundle or refine the request.")

    raise DevModeError("No safe patch path is available for this request class.")


def unified_diff(relative: str, before: str, after: str) -> str:
    diff = difflib.unified_diff(
        before.splitlines(),
        after.splitlines(),
        fromfile=f"before/{relative}",
        tofile=f"after/{relative}",
        lineterm="",
    )
    return "\n".join(diff)


def preview_request(request: str) -> dict[str, Any]:
    ensure_enabled()
    classification = classify_change(request)
    if not classification.get("allowed", False):
        return plan_dev_request(request)
    changes = build_changes(request, classification)
    previews = []
    for change in changes:
        previews.append(
            {
                "path": change["path"],
                "summary": change["summary"],
                "diff": unified_diff(change["path"], change["before"], change["after"]),
            }
        )
    log_event("dev_preview_generated", "ok", f"request={request}")
    return {
        "status": "preview",
        "summary": f"Prepared {len(previews)} UI change(s).",
        "request": request,
        "change_class": classification["change_class"],
        "apply_strategy": classification["apply_strategy"],
        "affected_files": [change["path"] for change in changes],
        "changes": previews,
    }


def validate_qml_file(path_text: str) -> dict[str, Any]:
    path = overlay_path_for(path_text) if overlay_path_for(path_text).exists() else base_path_for(path_text)
    if not path.exists():
        return {"status": "failed", "summary": f"QML file not found: {path_text}"}
    text = path.read_text(encoding="utf-8", errors="replace")
    status = "ok" if text.count("{") >= text.count("}") and "import QtQuick" in text else "degraded"
    return {"status": status, "summary": f"Validated {path_text}.", "details": "Brace balance and import checks completed."}


def run_dev_validation(files: list[str] | None = None) -> dict[str, Any]:
    files = files or []
    results: list[dict[str, Any]] = []
    overall = "ok"
    for relative in files:
        path = ROOT_DIR / relative
        if relative.startswith("apps/shell/qml/"):
            result = validate_qml_file(relative)
        elif path.suffix == ".py" or relative.startswith("scripts/"):
            proc = subprocess.run([sys.executable, "-m", "py_compile", str(path)], capture_output=True, text=True)
            result = {
                "status": "ok" if proc.returncode == 0 else "failed",
                "summary": f"Validated {relative}.",
                "details": proc.stderr.strip() or "py_compile passed",
            }
        else:
            result = {"status": "degraded", "summary": f"No validator for {relative}.", "details": "Best-effort validation only."}
        results.append(result)
        if result["status"] == "failed":
            overall = "failed"
        elif result["status"] == "degraded" and overall == "ok":
            overall = "degraded"
    log_agent_event("dev_validation_run", overall, f"files={','.join(files)}")
    return {"status": overall, "results": results}


def plan_dev_request(request: str) -> dict[str, Any]:
    state = ensure_state()
    classification = classify_change(request)
    files = resolve_dev_files(request, classification)
    approval_level = approval_level_for(classification["change_class"], files)
    summary = classification["reason"]
    if files:
        summary = f"{classification['reason']} Affected files: {', '.join(files[:4])}."
    plan = {
        "status": "planned" if classification["allowed"] else "denied",
        "request": request,
        "change_class": classification["change_class"],
        "apply_strategy": classification["apply_strategy"],
        "scope": classification["scope"],
        "allowed": classification["allowed"],
        "reason": classification["reason"],
        "affected_files": files,
        "approval_level": approval_level,
        "summary": summary,
    }
    state["dev_agent_last_request"] = request
    state["dev_agent_last_plan_summary"] = summary
    state["dev_agent_change_class"] = classification["change_class"]
    state["dev_agent_apply_strategy"] = classification["apply_strategy"]
    state["dev_agent_scope"] = classification["scope"]
    state["dev_agent_affected_files"] = files
    state["dev_agent_approval_level"] = approval_level
    save_state(state)
    log_agent_event("dev_plan_created", "ok" if classification["allowed"] else "denied", f"class={classification['change_class']} strategy={classification['apply_strategy']}")
    return plan


def create_patch_bundle(change_id: str, request: str, plan: dict[str, Any], changes: list[dict[str, Any]]) -> dict[str, Any]:
    bundle_root = DEV_PATCHES_ROOT / change_id
    bundle_root.mkdir(parents=True, exist_ok=True)
    diffs: list[dict[str, Any]] = []
    for change in changes:
        diff_text = unified_diff(change["path"], change["before"], change["after"])
        diff_path = bundle_root / (change["path"].replace("/", "__") + ".diff")
        diff_path.write_text(diff_text, encoding="utf-8")
        diffs.append({"path": change["path"], "diff_path": str(diff_path)})
    bundle = {
        "change_id": change_id,
        "request": request,
        "plan": plan,
        "diffs": diffs,
        "created_at": now_iso(),
    }
    write_json(bundle_root / "bundle.json", bundle)
    return {"bundle_root": str(bundle_root), "bundle": bundle}


def record_change(
    request: str,
    classification: dict[str, Any],
    changes: list[dict[str, Any]],
    validation: dict[str, Any],
    backup_root: Path,
    bundle_root: str,
) -> dict[str, Any]:
    history = ensure_history()
    state = ensure_state()
    change_id = backup_root.name
    entry = {
        "change_id": change_id,
        "request_text": request,
        "classified_type": classification["change_class"],
        "apply_mode": classification["apply_strategy"],
        "affected_files": [change["path"] for change in changes],
        "scope": classification["scope"],
        "timestamp": now_iso(),
        "validation_result": validation["status"],
        "rollback_available": True,
        "backup_root": str(backup_root),
        "bundle_root": bundle_root,
        "summary": "; ".join(change["summary"] for change in changes),
    }
    history.setdefault("changes", []).append(entry)
    history["changes"] = history["changes"][-MAX_HISTORY:]
    save_history(history)
    state["history"] = history["changes"][-MAX_HISTORY:]
    state["last_change_id"] = change_id
    state["last_change_summary"] = entry["summary"]
    state["last_change_files"] = entry["affected_files"]
    state["dev_agent_last_change_id"] = change_id
    state["dev_agent_last_request"] = request
    state["dev_agent_last_plan_summary"] = entry["summary"]
    state["dev_agent_change_class"] = classification["change_class"]
    state["dev_agent_apply_strategy"] = classification["apply_strategy"]
    state["dev_agent_scope"] = classification["scope"]
    state["dev_agent_affected_files"] = entry["affected_files"]
    state["dev_agent_validation_status"] = validation["status"]
    state["dev_agent_approval_level"] = approval_level_for(classification["change_class"], entry["affected_files"])
    state["dev_agent_history_size"] = len(history["changes"])
    save_state(state)
    return entry


def stage_system_update(change_id: str, files: list[str]) -> dict[str, Any]:
    log_agent_event("dev_stage_update", "ok", f"id={change_id} files={','.join(files)}")
    return {
        "status": "ok",
        "summary": "System change staged in the working tree. Apply it through Velyx Update when you are ready.",
        "change_id": change_id,
        "files": files,
    }


def apply_system_update(change_id: str) -> dict[str, Any]:
    result = subprocess.run(["velyx-update", "--source-root", str(ROOT_DIR)], capture_output=True, text=True, timeout=180)
    if result.returncode != 0:
        raise DevModeError(result.stderr.strip() or "Failed to apply staged system update")
    log_agent_event("dev_apply_system_update", "ok", f"id={change_id}")
    return {"status": "ok", "summary": "Staged system update applied through Velyx Update.", "details": result.stdout.strip()}


def mark_reboot_required(change_id: str) -> dict[str, Any]:
    log_agent_event("dev_mark_reboot_required", "ok", f"id={change_id}")
    return {"status": "ok", "summary": "This change affects critical runtime paths. Restart the runtime and plan for a reboot/test cycle.", "change_id": change_id}


def apply_changes_to_targets(changes: list[dict[str, Any]], backup_root: Path) -> list[str]:
    applied_files: list[str] = []
    for change in changes:
        relative = change["path"]
        before = change["before"]
        target_mode = change.get("target", "overlay")
        target = overlay_path_for(relative) if target_mode == "overlay" else (ROOT_DIR / relative)
        target.parent.mkdir(parents=True, exist_ok=True)
        backup = backup_root / relative
        backup.parent.mkdir(parents=True, exist_ok=True)
        backup.write_text(before, encoding="utf-8")
        target.write_text(change["after"], encoding="utf-8")
        applied_files.append(relative)
    return applied_files


def apply_dev_request(request: str) -> dict[str, Any]:
    ensure_enabled()
    plan = plan_dev_request(request)
    if not plan.get("allowed", False):
        raise DevModeError(plan.get("reason", "Dev change is not allowed"))
    changes = build_changes(request, plan)
    max_files = int(ensure_config().get("max_files_per_change", 4))
    if len(changes) > max_files:
        raise DevModeError(f"Dev change exceeds the max_files_per_change policy ({max_files})")
    change_id = f"{datetime.now(timezone.utc).strftime('%Y%m%dT%H%M%SZ')}-{uuid.uuid4().hex[:6]}"
    backup_root = OVERLAY_HISTORY / change_id if plan["apply_strategy"] == "live_apply" else DEV_PATCHES_ROOT / change_id / "backup"
    applied_files = apply_changes_to_targets(changes, backup_root)
    validation = run_dev_validation(applied_files)
    bundle = create_patch_bundle(change_id, request, plan, changes)
    entry = record_change(request, plan, changes, validation, backup_root, bundle["bundle_root"])
    state = ensure_state()
    state["last_visual_request"] = request
    save_state(state)
    result: dict[str, Any] = {
        "status": "ok" if validation["status"] != "failed" else "failed",
        "change_id": change_id,
        "summary": entry["summary"],
        "files": applied_files,
        "change_class": plan["change_class"],
        "apply_strategy": plan["apply_strategy"],
        "validation": validation,
        "bundle_root": bundle["bundle_root"],
    }
    if plan["apply_strategy"] == "live_apply":
        result["restart"] = restart_shell_dev()
    elif plan["apply_strategy"] == "staged_update":
        result["staged"] = stage_system_update(change_id, applied_files)
    elif plan["apply_strategy"] == "reboot_required":
        result["reboot_required"] = mark_reboot_required(change_id)
    log_event("dev_patch_applied", result["status"], f"id={change_id} files={','.join(applied_files)}")
    log_agent_event("dev_apply_completed", result["status"], f"id={change_id} strategy={plan['apply_strategy']}")
    return result


def apply_request(request: str) -> dict[str, Any]:
    return apply_dev_request(request)


def screenshot_file_path(label: str = "ui") -> Path:
    SCREENSHOT_ROOT.mkdir(parents=True, exist_ok=True)
    timestamp = datetime.now(timezone.utc).strftime("%Y%m%dT%H%M%SZ")
    return SCREENSHOT_ROOT / f"velyx_{label}_{timestamp}_{uuid.uuid4().hex[:6]}.png"


def capture_with_linux_tools(target: Path) -> bool:
    commands = [
        ["grim", str(target)],
        ["gnome-screenshot", "-f", str(target)],
        ["scrot", str(target)],
        ["import", "-window", "root", str(target)],
    ]
    for command in commands:
        try:
            result = subprocess.run(command, capture_output=True, text=True, timeout=8)
        except Exception:
            continue
        if result.returncode == 0 and target.exists() and target.stat().st_size > 0:
            return True
    return False


def capture_with_windows_tools(target: Path) -> bool:
    script = f"""
Add-Type -AssemblyName System.Windows.Forms
Add-Type -AssemblyName System.Drawing
$bounds = [System.Windows.Forms.Screen]::PrimaryScreen.Bounds
$bitmap = New-Object System.Drawing.Bitmap $bounds.Width, $bounds.Height
$graphics = [System.Drawing.Graphics]::FromImage($bitmap)
$graphics.CopyFromScreen($bounds.Location, [System.Drawing.Point]::Empty, $bounds.Size)
$bitmap.Save('{str(target).replace("'", "''")}', [System.Drawing.Imaging.ImageFormat]::Png)
$graphics.Dispose()
$bitmap.Dispose()
"""
    try:
        result = subprocess.run(
            ["powershell", "-NoProfile", "-Command", script],
            capture_output=True,
            text=True,
            timeout=8,
        )
    except Exception:
        return False
    return result.returncode == 0 and target.exists() and target.stat().st_size > 0


def png_dimensions(path: Path) -> tuple[int, int]:
    with path.open("rb") as handle:
        signature = handle.read(8)
        if signature != b"\x89PNG\r\n\x1a\n":
            return 0, 0
        handle.read(4)
        chunk = handle.read(4)
        if chunk != b"IHDR":
            return 0, 0
        width, height = struct.unpack(">II", handle.read(8))
        return int(width), int(height)


def screenshot_metadata(path: Path) -> dict[str, Any]:
    width, height = png_dimensions(path) if path.exists() else (0, 0)
    return {
        "path": str(path),
        "width": width,
        "height": height,
        "size_bytes": path.stat().st_size if path.exists() else 0,
        "mtime": path.stat().st_mtime if path.exists() else 0,
    }


def compare_screenshot_paths(before_path: str, after_path: str) -> dict[str, Any]:
    before = Path(before_path)
    after = Path(after_path)
    before_meta = screenshot_metadata(before)
    after_meta = screenshot_metadata(after)
    changed = False
    if before.exists() and after.exists():
        changed = before.read_bytes() != after.read_bytes()
    return {
        "before": before_meta,
        "after": after_meta,
        "changed": changed,
        "size_delta_bytes": after_meta["size_bytes"] - before_meta["size_bytes"],
        "same_dimensions": before_meta["width"] == after_meta["width"] and before_meta["height"] == after_meta["height"],
    }


def capture_ui_screenshot(label: str = "ui") -> dict[str, Any]:
    state = ensure_enabled()
    target = screenshot_file_path(label)
    ok = False
    if sys.platform.startswith("win"):
        ok = capture_with_windows_tools(target)
    else:
        ok = capture_with_linux_tools(target)
    if not ok:
        log_event("dev_screenshot_capture", "failed", "capture_unavailable")
        raise DevModeError("Could not capture a shell screenshot in this environment")
    previous = state.get("last_screenshot", "")
    state["previous_screenshot"] = previous
    state["last_screenshot"] = str(target)
    save_state(state)
    log_event("dev_screenshot_capture", "ok", f"path={target}")
    return {
        "status": "ok",
        "path": str(target),
        "previous": previous,
        "metadata": screenshot_metadata(target),
    }


def get_last_screenshot() -> dict[str, Any]:
    state = ensure_state()
    return {
        "last_screenshot": state.get("last_screenshot", ""),
        "previous_screenshot": state.get("previous_screenshot", ""),
    }


def run_json_command(program: str, arguments: list[str], timeout: int = 20) -> dict[str, Any]:
    executable = shutil.which(program)
    command: list[str]
    if executable is None:
        local_script = ROOT_DIR / "scripts" / program
        if local_script.exists():
            command = [sys.executable, str(local_script), *arguments]
        else:
            command = [program, *arguments]
    else:
        command = [executable, *arguments]
    result = subprocess.run(command, capture_output=True, text=True, timeout=timeout)
    if result.returncode != 0:
        raise DevModeError(result.stderr.strip() or f"Command failed: {' '.join(command)}")
    return json.loads(result.stdout or "{}")


def analyze_ui_screenshot(
    image_path: str | None = None,
    request: str = "",
    allow_auto_refine: bool = True,
    visual_iteration: int = 0,
) -> dict[str, Any]:
    state = ensure_enabled()
    target = image_path or state.get("last_screenshot", "")
    if not target:
        raise DevModeError("No screenshot is available for analysis")
    previous = state.get("previous_screenshot", "")
    change_summary = state.get("last_change_summary", "")
    analysis = run_json_command(
        "velyx-ai",
        [
            "visual-analyze",
            target,
            "--request",
            request or state.get("last_visual_request", ""),
            "--change-summary",
            change_summary,
            "--previous",
            previous,
        ],
        timeout=25,
    )
    state["last_visual_status"] = analysis.get("status", "ok")
    state["last_visual_summary"] = analysis.get("summary", "")
    state["last_visual_recommendation"] = analysis.get("recommendation", "")
    state["pending_refinement_request"] = analysis.get("recommended_refinement_request", "")
    state["last_visual_iteration"] = visual_iteration
    state["last_comparison"] = analysis.get("comparison", {})
    save_state(state)
    log_event("dev_visual_analysis", "ok", f"request={request or state.get('last_visual_request', '')}")

    auto_request = analysis.get("recommended_refinement_request", "")
    can_auto = (
        state.get("auto_refine", False)
        and allow_auto_refine
        and bool(auto_request)
        and bool(analysis.get("safe_to_auto_run", False))
        and visual_iteration < int(state.get("max_visual_iterations", MAX_VISUAL_ITERATIONS))
    )
    if not can_auto:
        return analysis

    applied = apply_request(auto_request)
    restart = restart_shell_dev()
    capture = capture_ui_screenshot("refine")
    follow_up = analyze_ui_screenshot(
        capture["path"],
        request=auto_request,
        allow_auto_refine=False,
        visual_iteration=visual_iteration + 1,
    )
    return {
        "status": "ok",
        "summary": follow_up.get("summary", analysis.get("summary", "")),
        "recommendation": follow_up.get("recommendation", analysis.get("recommendation", "")),
        "recommended_refinement_request": follow_up.get("recommended_refinement_request", ""),
        "comparison": follow_up.get("comparison", analysis.get("comparison", {})),
        "analysis": analysis,
        "auto_refinement": {
            "request": auto_request,
            "applied": applied,
            "restart": restart,
            "capture": capture,
            "follow_up_analysis": follow_up,
        },
    }


def apply_next_refinement() -> dict[str, Any]:
    state = ensure_enabled()
    refinement = state.get("pending_refinement_request", "")
    if not refinement:
        raise DevModeError("No pending visual refinement is available")
    applied = apply_request(refinement)
    restart = restart_shell_dev()
    capture = capture_ui_screenshot("refine")
    analysis = analyze_ui_screenshot(capture["path"], request=refinement, allow_auto_refine=False, visual_iteration=int(state.get("last_visual_iteration", 0)) + 1)
    return {
        "status": "ok",
        "summary": f"Applied refinement: {refinement}",
        "applied": applied,
        "restart": restart,
        "capture": capture,
        "analysis": analysis,
    }


def restart_shell_dev() -> dict[str, Any]:
    commands = [
        ["systemctl", "--user", "restart", "velyx-shell.service"],
        ["velyx-restart.sh"],
    ]
    for command in commands:
        try:
            result = subprocess.run(command, capture_output=True, text=True, timeout=20)
        except Exception:
            continue
        if result.returncode == 0:
            log_event("dev_shell_restarted", "ok", f"command={' '.join(command)}")
            return {
                "status": "ok",
                "summary": "Velyx Shell restart requested for live UI reload.",
                "details": result.stdout.strip() or "Restart command completed.",
            }
    log_event("dev_shell_restarted", "degraded", "restart command unavailable")
    return {
        "status": "degraded",
        "summary": "UI files changed, but shell restart was not available in this environment.",
        "details": "Run 'systemctl --user restart velyx-shell.service' on a Velyx session host.",
    }


def history_list() -> dict[str, Any]:
    return {"changes": ensure_history().get("changes", [])}


def restore_change(change_id: str) -> dict[str, Any]:
    history = ensure_history()
    state = ensure_state()
    entry = next((item for item in history.get("changes", []) if item.get("change_id") == change_id), None)
    if not entry:
        raise DevModeError(f"Change not found: {change_id}")
    backup_root = Path(entry.get("backup_root", ""))
    restored: list[str] = []
    for relative in entry.get("affected_files", []):
        backup = backup_root / relative
        if not backup.exists():
            continue
        target = overlay_path_for(relative) if entry.get("apply_mode") == "live_apply" else (ROOT_DIR / relative)
        target.parent.mkdir(parents=True, exist_ok=True)
        shutil.copy2(backup, target)
        restored.append(relative)
    history["changes"] = [item for item in history.get("changes", []) if item.get("change_id") != change_id]
    save_history(history)
    state["history"] = history["changes"][-MAX_HISTORY:]
    if history["changes"]:
        last = history["changes"][-1]
        state["last_change_id"] = last.get("change_id", "")
        state["last_change_summary"] = last.get("summary", "")
        state["last_change_files"] = last.get("affected_files", [])
    else:
        state["last_change_id"] = ""
        state["last_change_summary"] = ""
        state["last_change_files"] = []
    state["dev_agent_history_size"] = len(history["changes"])
    save_state(state)
    restart = restart_shell_dev() if entry.get("apply_mode") == "live_apply" else {"status": "ok", "summary": "Restore completed. Restart or apply update when appropriate."}
    log_event("dev_restore", "ok", f"id={change_id}")
    log_agent_event("dev_restore", "ok", f"id={change_id}")
    return {"status": restart["status"], "summary": f"Restored {change_id}.", "files": restored, "restart": restart}


def rollback_last_change() -> dict[str, Any]:
    history = ensure_history()
    if not history.get("changes"):
        raise DevModeError("No dev changes available for rollback")
    return restore_change(history["changes"][-1]["change_id"])


def export_patch_bundle(change_id: str | None = None) -> dict[str, Any]:
    history = ensure_history()
    if not history.get("changes"):
        raise DevModeError("No dev changes available for export")
    entry = history["changes"][-1] if not change_id else next((item for item in history["changes"] if item.get("change_id") == change_id), None)
    if not entry:
        raise DevModeError(f"Change not found: {change_id}")
    return {
        "status": "ok",
        "change_id": entry.get("change_id", ""),
        "bundle_root": entry.get("bundle_root", ""),
        "summary": f"Patch bundle exported at {entry.get('bundle_root', '')}.",
    }


def create_dev_commit_message_suggestion(change_id: str | None = None) -> dict[str, Any]:
    history = ensure_history()
    if not history.get("changes"):
        raise DevModeError("No dev changes available")
    entry = history["changes"][-1] if not change_id else next((item for item in history["changes"] if item.get("change_id") == change_id), None)
    if not entry:
        raise DevModeError(f"Change not found: {change_id}")
    message = f"{entry.get('classified_type', 'dev')}: {entry.get('summary', 'update Velyx dev change')}"
    return {"status": "ok", "change_id": entry.get("change_id", ""), "message": message}


def usage() -> str:
    return "\n".join(
        [
            "Usage:",
            "  velyx-dev enable",
            "  velyx-dev disable",
            "  velyx-dev set-mode disabled|ui_live_only|full_dev",
            "  velyx-dev status",
            "  velyx-dev list-ui-files [all|qml|src|design]",
            "  velyx-dev list-system-modules",
            "  velyx-dev list-qml-components",
            "  velyx-dev search-ui-component <query>",
            "  velyx-dev search-code <query>",
            "  velyx-dev read-ui-file <path>",
            "  velyx-dev read-dev-file <path>",
            "  velyx-dev snapshot-ui-state",
            '  velyx-dev preview-ui-diff "<request>"',
            '  velyx-dev patch-ui-file "<request>"',
            '  velyx-dev dev-agent-plan "<request>"',
            '  velyx-dev dev-agent-apply "<request>"',
            "  velyx-dev validate-code-scope <path>",
            "  velyx-dev validate-qml-file <path>",
            "  velyx-dev run-dev-validation [file1 file2 ...]",
            "  velyx-dev history",
            "  velyx-dev restore <change_id>",
            "  velyx-dev export-patch-bundle [change_id]",
            "  velyx-dev commit-message [change_id]",
            "  velyx-dev capture-ui-screenshot",
            "  velyx-dev get-last-screenshot",
            "  velyx-dev compare-screenshots <before> <after>",
            '  velyx-dev analyze-ui-screenshot [<path>] --request "<request>"',
            "  velyx-dev set-auto-refine true|false",
            "  velyx-dev apply-next-refinement",
            "  velyx-dev restart-shell-dev",
            "  velyx-dev rollback",
        ]
    )


def main(argv: list[str]) -> int:
    ensure_config()
    ensure_history()
    ensure_state()
    if len(argv) < 2:
        print(usage(), file=sys.stderr)
        return 1
    command = argv[1]
    try:
        if command == "enable":
            print_json(enable_dev_mode())
            return 0
        if command == "disable":
            print_json(disable_dev_mode())
            return 0
        if command == "set-mode":
            if len(argv) < 3:
                raise DevModeError("Missing dev mode")
            print_json(set_dev_agent_mode(argv[2]))
            return 0
        if command == "status":
            print_json(status())
            return 0
        if command == "list-ui-files":
            scope = argv[2] if len(argv) > 2 else "all"
            print_json({"files": list_ui_files(scope)})
            return 0
        if command == "list-system-modules":
            print_json({"modules": list_system_modules()})
            return 0
        if command == "list-qml-components":
            print_json({"components": list_qml_components()})
            return 0
        if command == "search-ui-component":
            if len(argv) < 3:
                raise DevModeError("Missing component query")
            print_json({"results": search_ui_component(" ".join(argv[2:]))})
            return 0
        if command == "search-code":
            if len(argv) < 3:
                raise DevModeError("Missing code query")
            print_json({"results": search_code(" ".join(argv[2:]))})
            return 0
        if command == "read-ui-file":
            if len(argv) < 3:
                raise DevModeError("Missing UI file path")
            print_json(read_ui_file(argv[2]))
            return 0
        if command == "read-dev-file":
            if len(argv) < 3:
                raise DevModeError("Missing dev file path")
            print_json(read_dev_file(argv[2]))
            return 0
        if command == "snapshot-ui-state":
            print_json(create_snapshot())
            return 0
        if command == "preview-ui-diff":
            if len(argv) < 3:
                raise DevModeError("Missing UI change request")
            print_json(preview_request(" ".join(argv[2:])))
            return 0
        if command == "patch-ui-file":
            if len(argv) < 3:
                raise DevModeError("Missing UI change request")
            print_json(apply_request(" ".join(argv[2:])))
            return 0
        if command == "dev-agent-plan":
            if len(argv) < 3:
                raise DevModeError("Missing dev agent request")
            print_json(plan_dev_request(" ".join(argv[2:])))
            return 0
        if command == "dev-agent-apply":
            if len(argv) < 3:
                raise DevModeError("Missing dev agent request")
            print_json(apply_dev_request(" ".join(argv[2:])))
            return 0
        if command == "validate-code-scope":
            if len(argv) < 3:
                raise DevModeError("Missing path")
            print_json({"path": argv[2], "allowed": validate_code_scope(argv[2])})
            return 0
        if command == "validate-qml-file":
            if len(argv) < 3:
                raise DevModeError("Missing QML file path")
            print_json(validate_qml_file(argv[2]))
            return 0
        if command == "run-dev-validation":
            print_json(run_dev_validation(argv[2:]))
            return 0
        if command == "history":
            print_json(history_list())
            return 0
        if command == "restore":
            if len(argv) < 3:
                raise DevModeError("Missing change id")
            print_json(restore_change(argv[2]))
            return 0
        if command == "export-patch-bundle":
            print_json(export_patch_bundle(argv[2] if len(argv) > 2 else None))
            return 0
        if command == "commit-message":
            print_json(create_dev_commit_message_suggestion(argv[2] if len(argv) > 2 else None))
            return 0
        if command == "capture-ui-screenshot":
            print_json(capture_ui_screenshot())
            return 0
        if command == "get-last-screenshot":
            print_json(get_last_screenshot())
            return 0
        if command == "compare-screenshots":
            if len(argv) < 4:
                raise DevModeError("Missing screenshot paths")
            print_json(compare_screenshot_paths(argv[2], argv[3]))
            return 0
        if command == "analyze-ui-screenshot":
            path_arg = None
            request = ""
            index = 2
            while index < len(argv):
                if argv[index] == "--request" and index + 1 < len(argv):
                    request = argv[index + 1]
                    index += 2
                    continue
                if not argv[index].startswith("--") and path_arg is None:
                    path_arg = argv[index]
                index += 1
            print_json(analyze_ui_screenshot(path_arg, request=request))
            return 0
        if command == "set-auto-refine":
            if len(argv) < 3:
                raise DevModeError("Missing auto refine value")
            print_json(set_auto_refine(argv[2].lower() in {"1", "true", "yes", "on"}))
            return 0
        if command == "apply-next-refinement":
            print_json(apply_next_refinement())
            return 0
        if command == "restart-shell-dev":
            print_json(restart_shell_dev())
            return 0
        if command == "rollback":
            print_json(rollback_last_change())
            return 0
        print(usage(), file=sys.stderr)
        return 1
    except Exception as exc:
        log_event("dev_command_failed", "failed", str(exc))
        print(str(exc), file=sys.stderr)
        return 1


if __name__ == "__main__":
    raise SystemExit(main(sys.argv))
