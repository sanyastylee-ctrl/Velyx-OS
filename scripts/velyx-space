#!/usr/bin/env python3
import json
import os
import shutil
import subprocess
import sys
from datetime import datetime, timezone
from pathlib import Path


def now_iso() -> str:
    return datetime.now(timezone.utc).replace(microsecond=0).isoformat().replace("+00:00", "Z")


def load_env_file() -> dict:
    env_path = Path(os.environ.get("XDG_CONFIG_HOME", str(Path.home() / ".config"))) / "velyx" / "velyx.env"
    values = {}
    if env_path.exists():
        for line in env_path.read_text(encoding="utf-8").splitlines():
            line = line.strip()
            if not line or line.startswith("#") or "=" not in line:
                continue
            key, value = line.split("=", 1)
            values[key.strip()] = value.strip()
    return values


ENV_FILE_VALUES = load_env_file()
STATE_DIR = Path(os.environ.get("VELYX_STATE_DIR") or ENV_FILE_VALUES.get("VELYX_STATE_DIR") or (Path.home() / ".velyx"))
SPACES_REGISTRY = Path(
    os.environ.get("VELYX_SPACES_REGISTRY")
    or ENV_FILE_VALUES.get("VELYX_SPACES_REGISTRY")
    or (STATE_DIR / "spaces_registry.json")
)
SPACES_LOG = STATE_DIR / "spaces.log"


def log_event(event: str, status: str, detail: str = "") -> None:
    STATE_DIR.mkdir(parents=True, exist_ok=True)
    with SPACES_LOG.open("a", encoding="utf-8") as fh:
        fh.write(f"{now_iso()} event={event} status={status} {detail}\n")


def default_registry() -> dict:
    timestamp = now_iso()
    return {
        "active_space_id": "general",
        "spaces": [
            {
                "space_id": "general",
                "display_name": "General",
                "description": "Общий рабочий контекст",
                "apps": ["com.velyx.browser", "com.velyx.files"],
                "autostart_apps": ["com.velyx.browser"],
                "required_apps": [],
                "preferred_active_app": "com.velyx.browser",
                "security_mode": "normal",
                "permissions_profile": "default",
                "focus_policy": "prefer_active_app",
                "ui_layout": "standard",
                "status": "active",
                "created_at": timestamp,
                "updated_at": timestamp,
                "source": "system",
            },
            {
                "space_id": "development",
                "display_name": "Development",
                "description": "Контекст разработки и проверки",
                "apps": ["com.velyx.browser", "com.velyx.files", "com.velyx.testapp"],
                "autostart_apps": ["com.velyx.files"],
                "required_apps": [],
                "preferred_active_app": "com.velyx.files",
                "security_mode": "relaxed",
                "permissions_profile": "developer",
