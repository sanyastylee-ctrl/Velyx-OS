#!/usr/bin/env bash
set -euo pipefail

ENV_FILE="${XDG_CONFIG_HOME:-$HOME/.config}/velyx/velyx.env"
if [[ -f "${ENV_FILE}" ]]; then
  # shellcheck disable=SC1090
  source "${ENV_FILE}"
fi

STATE_DIR="${VELYX_STATE_DIR:-$HOME/.velyx}"
STATE_FILE="${STATE_DIR}/update_state.json"
APP_REGISTRY="${VELYX_APP_REGISTRY:-${STATE_DIR}/apps_registry.json}"
SPACES_REGISTRY="${VELYX_SPACES_REGISTRY:-${STATE_DIR}/spaces_registry.json}"
INTENTS_REGISTRY="${VELYX_INTENTS_REGISTRY:-${STATE_DIR}/intents_registry.json}"
INTENT_STATE="${STATE_DIR}/intent_state.json"
RULES_REGISTRY="${VELYX_RULES_REGISTRY:-${STATE_DIR}/rules_registry.json}"
RULES_STATE="${STATE_DIR}/rules_state.json"
AGENT_STATE="${STATE_DIR}/agent_state.json"
AI_CONFIG="${STATE_DIR}/ai_config.json"
AI_STATE_FILE="${STATE_DIR}/ai_state.json"
ASSISTANT_CONFIG="${STATE_DIR}/assistant_config.json"
ASSISTANT_STATE_FILE="${STATE_DIR}/assistant_state.json"
MODEL_CONFIG="${STATE_DIR}/model_config.json"
MODEL_STATE_FILE="${STATE_DIR}/model_state.json"
MODEL_REGISTRY="${STATE_DIR}/model_registry.json"
NETWORK_STATE_FILE="${STATE_DIR}/network_state.json"
FIRSTBOOT_STATE="${STATE_DIR}/first_boot_state.json"
FIRSTBOOT_STATE_CANONICAL="${STATE_DIR}/first_boot.json"
SHELL_STATE_FILE="${STATE_DIR}/shell_state.json"
DEV_MODE_STATE="${STATE_DIR}/dev_mode.json"
DEV_MODE_CONFIG="${STATE_DIR}/dev_mode_config.json"
DEV_HISTORY="${STATE_DIR}/dev_history.json"
ENTRY_LOG="${STATE_DIR}/entry.log"
LIVE_LOG="${STATE_DIR}/live_mode.log"

unit_state() {
  local unit="$1"
  systemctl --user is-active "${unit}" 2>/dev/null || echo "down"
}

service_prop() {
  local unit="$1"
  local prop="$2"
  systemctl --user show "${unit}" -p "${prop}" 2>/dev/null | sed -E "s/^${prop}=//" || true
}

dbus_state() {
  local name="$1"
  if ! command -v busctl >/dev/null 2>&1; then
    echo "busctl-missing"
    return
  fi
  if busctl --user list 2>/dev/null | awk '{print $1}' | grep -Fxq "${name}"; then
    echo "available"
  else
    echo "missing"
  fi
}

state_string() {
  local key="$1"
  if [[ ! -f "${STATE_FILE}" ]]; then
    return 0
  fi
  grep -oE "\"${key}\"[[:space:]]*:[[:space:]]*\"[^\"]*\"" "${STATE_FILE}" | head -n1 | sed -E 's/.*:[[:space:]]*"([^"]*)"/\1/' || true
}

state_bool() {
  local key="$1"
  if [[ ! -f "${STATE_FILE}" ]]; then
    printf 'false\n'
    return 0
  fi
  grep -oE "\"${key}\"[[:space:]]*:[[:space:]]*(true|false)" "${STATE_FILE}" | head -n1 | sed -E 's/.*:[[:space:]]*(true|false)/\1/' || printf 'false\n'
}

json_bool_string() {
  local key="$1"
  local file="$2"
  if [[ ! -f "${file}" ]]; then
    printf 'false\n'
    return 0
  fi
  grep -oE "\"${key}\"[[:space:]]*:[[:space:]]*(true|false)" "${file}" | head -n1 | sed -E 's/.*:[[:space:]]*(true|false)/\1/' || printf 'false\n'
}

json_number_string() {
  local key="$1"
  local file="$2"
  if [[ ! -f "${file}" ]]; then
    printf '0\n'
    return 0
  fi
  grep -oE "\"${key}\"[[:space:]]*:[[:space:]]*[0-9]+" "${file}" | head -n1 | sed -E 's/.*:[[:space:]]*([0-9]+)/\1/' || printf '0\n'
}

app_count() {
  if [[ ! -f "${APP_REGISTRY}" ]]; then
    printf '0\n'
    return 0
  fi
  grep -o '"app_id"' "${APP_REGISTRY}" | wc -l | awk '{print $1}'
}

spaces_count() {
  if [[ ! -f "${SPACES_REGISTRY}" ]]; then
    printf '0\n'
    return 0
  fi
  grep -o '"space_id"' "${SPACES_REGISTRY}" | wc -l | awk '{print $1}'
}

intents_count() {
  if [[ ! -f "${INTENTS_REGISTRY}" ]]; then
    printf '0\n'
    return 0
  fi
  grep -o '"intent_id"' "${INTENTS_REGISTRY}" | wc -l | awk '{print $1}'
}

rules_count() {
  if [[ ! -f "${RULES_REGISTRY}" ]]; then
    printf '0\n'
    return 0
  fi
  grep -o '"rule_id"' "${RULES_REGISTRY}" | wc -l | awk '{print $1}'
}

intent_state_string() {
  local key="$1"
  local file="${2:-$INTENT_STATE}"
  if [[ ! -f "${file}" ]]; then
    return 0
  fi
  grep -oE "\"${key}\"[[:space:]]*:[[:space:]]*\"[^\"]*\"" "${file}" | head -n1 | sed -E 's/.*:[[:space:]]*"([^"]*)"/\1/' || true
}

active_space() {
  if [[ ! -f "${SPACES_REGISTRY}" ]]; then
    return 0
  fi
  grep -oE '"active_space_id"[[:space:]]*:[[:space:]]*"[^"]*"' "${SPACES_REGISTRY}" | head -n1 | sed -E 's/.*:[[:space:]]*"([^"]*)"/\1/' || true
}

printf 'launcher: %s (dbus=%s)\n' "$(unit_state velyx-launcher.service)" "$(dbus_state com.velyx.Launcher)"
printf 'permissions: %s (dbus=%s)\n' "$(unit_state velyx-permissions.service)" "$(dbus_state com.velyx.Permissions)"
printf 'session-manager: %s (dbus=%s)\n' "$(unit_state velyx-session-manager.service)" "$(dbus_state com.velyx.SessionManager)"
printf 'shell: %s\n' "$(unit_state velyx-shell.service)"
printf 'firstboot-entry: %s\n' "$(unit_state velyx-firstboot.service)"
printf 'shell-substate: %s\n' "$(service_prop velyx-shell.service SubState)"
printf 'shell-result: %s\n' "$(service_prop velyx-shell.service Result)"
printf 'shell-restarts: %s\n' "$(service_prop velyx-shell.service NRestarts)"
printf 'session-target: %s\n' "$(unit_state velyx-session.target)"
printf 'update-engine: %s (dbus=%s)\n' "$(unit_state velyx-update-engine.service)" "$(dbus_state com.velyx.UpdateEngine)"
printf 'recovery: %s (dbus=%s)\n' "$(unit_state velyx-recovery.service)" "$(dbus_state com.velyx.Recovery)"
printf 'update-state: %s\n' "$(state_string update_state)"
printf 'current-version: %s\n' "$(state_string current_version)"
printf 'staged-version: %s\n' "$(state_string staged_version)"
printf 'last-good-version: %s\n' "$(state_string last_good_version)"
printf 'last-update-result: %s\n' "$(state_string last_update_result)"
printf 'rollback-available: %s\n' "$(state_bool rollback_available)"
printf 'recovery-needed: %s\n' "$(state_bool recovery_needed)"
printf 'app-registry: %s (count=%s)\n' "${APP_REGISTRY}" "$(app_count)"
printf 'spaces-registry: %s (count=%s active=%s)\n' "${SPACES_REGISTRY}" "$(spaces_count)" "$(active_space)"
printf 'intents-registry: %s (count=%s last=%s result=%s)\n' "${INTENTS_REGISTRY}" "$(intents_count)" "$(intent_state_string last_intent_id)" "$(intent_state_string last_result)"
printf 'rules-registry: %s (count=%s last=%s result=%s)\n' "${RULES_REGISTRY}" "$(rules_count)" "$(intent_state_string last_rule_id "${RULES_STATE}")" "$(intent_state_string last_result "${RULES_STATE}")"
printf 'agent-state: %s (last=%s result=%s)\n' "${AGENT_STATE}" "$(intent_state_string last_action "${AGENT_STATE}")" "$(intent_state_string last_result "${AGENT_STATE}")"
printf 'ai-config: %s (mode=%s provider=%s model=%s)\n' "${AI_CONFIG}" "$(intent_state_string mode "${AI_CONFIG}")" "$(intent_state_string provider "${AI_CONFIG}")" "$(intent_state_string model_name "${AI_CONFIG}")"
printf 'ai-state: %s (available=%s result=%s)\n' "${AI_STATE_FILE}" "$(json_bool_string model_available "${AI_STATE_FILE}")" "$(intent_state_string last_suggestion_result "${AI_STATE_FILE}")"
printf 'assistant-config: %s (mode=%s network=%s)\n' "${ASSISTANT_CONFIG}" "$(intent_state_string mode "${ASSISTANT_CONFIG}")" "$(intent_state_string network_access "${ASSISTANT_CONFIG}")"
printf 'assistant-state: %s (status=%s pending=%s)\n' "${ASSISTANT_STATE_FILE}" "$(intent_state_string current_execution_status "${ASSISTANT_STATE_FILE}")" "$(intent_state_string request_id "${ASSISTANT_STATE_FILE}")"
printf 'network-state: %s (state=%s update=%s ai=%s)\n' "${NETWORK_STATE_FILE}" "$(intent_state_string state "${NETWORK_STATE_FILE}")" "$(intent_state_string update_reachability "${NETWORK_STATE_FILE}")" "$(intent_state_string ai_backend_reachability "${NETWORK_STATE_FILE}")"
printf 'dev-mode: %s (enabled=%s last-change=%s)\n' "${DEV_MODE_STATE}" "$(json_bool_string enabled "${DEV_MODE_STATE}")" "$(intent_state_string last_change_summary "${DEV_MODE_STATE}")"
printf 'dev-config: %s (mode=%s auto-live=%s system-staging=%s)\n' "${DEV_MODE_CONFIG}" "$(intent_state_string mode "${DEV_MODE_CONFIG}")" "$(json_bool_string auto_apply_live_changes "${DEV_MODE_CONFIG}")" "$(json_bool_string allow_system_staging "${DEV_MODE_CONFIG}")"
printf 'dev-history: %s (entries=%s)\n' "${DEV_HISTORY}" "$( [[ -f "${DEV_HISTORY}" ]] && grep -o '"change_id"' "${DEV_HISTORY}" | wc -l | awk '{print $1}' || printf '0' )"
printf 'model-config: %s (mode=%s small=%s main=%s heavy=%s)\n' "${MODEL_CONFIG}" "$(intent_state_string selection_mode "${MODEL_CONFIG}")" "$(intent_state_string default_small_model "${MODEL_CONFIG}")" "$(intent_state_string default_main_model "${MODEL_CONFIG}")" "$(intent_state_string default_heavy_model "${MODEL_CONFIG}")"
printf 'model-state: %s (active=%s profile=%s backend=%s available=%s)\n' "${MODEL_STATE_FILE}" "$(intent_state_string active_model "${MODEL_STATE_FILE}")" "$(intent_state_string active_profile "${MODEL_STATE_FILE}")" "$(intent_state_string backend_status "${MODEL_STATE_FILE}")" "$(json_bool_string model_available "${MODEL_STATE_FILE}")"
printf 'model-registry: %s (count=%s)\n' "${MODEL_REGISTRY}" "$( [[ -f "${MODEL_REGISTRY}" ]] && grep -o '"model_id"' "${MODEL_REGISTRY}" | wc -l | awk '{print $1}' || printf '0' )"
printf 'first-boot: %s (completed=%s step=%s)\n' "${FIRSTBOOT_STATE_CANONICAL}" "$(json_bool_string completed "${FIRSTBOOT_STATE_CANONICAL}")" "$(intent_state_string step "${FIRSTBOOT_STATE_CANONICAL}")"
printf 'first-boot-compat: %s (required=%s step=%s ready=%s)\n' "${FIRSTBOOT_STATE}" "$(json_bool_string first_boot_required "${FIRSTBOOT_STATE}")" "$(intent_state_string current_step "${FIRSTBOOT_STATE}")" "$(json_bool_string system_ready "${FIRSTBOOT_STATE}")"
printf 'shell-state: %s (result=%s recent-failures=%s recovery=%s)\n' "${SHELL_STATE_FILE}" "$(intent_state_string last_result "${SHELL_STATE_FILE}")" "$(json_number_string recent_failure_count "${SHELL_STATE_FILE}")" "$(json_bool_string recovery_suggested "${SHELL_STATE_FILE}")"
printf 'entry-log: %s (%s)\n' "${ENTRY_LOG}" "$( [[ -f "${ENTRY_LOG}" ]] && echo present || echo missing )"
printf 'live-log: %s (%s)\n' "${LIVE_LOG}" "$( [[ -f "${LIVE_LOG}" ]] && echo present || echo missing )"
printf 'xprop: %s\n' "$(command -v xprop >/dev/null 2>&1 && echo available || echo missing)"
printf 'wmctrl: %s\n' "$(command -v wmctrl >/dev/null 2>&1 && echo available || echo missing)"
printf 'xdotool: %s\n' "$(command -v xdotool >/dev/null 2>&1 && echo available || echo missing)"
