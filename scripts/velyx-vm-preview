#!/usr/bin/env python3
import json
import sys
from pathlib import Path


ROOT = Path(__file__).resolve().parent.parent


def profile_path() -> Path:
    local = ROOT / "profiles" / "velyx-vm-preview.json"
    if local.exists():
        return local
    installed = ROOT / "share" / "profiles" / "velyx-vm-preview.json"
    if installed.exists():
        return installed
    raise FileNotFoundError("velyx-vm-preview profile not found")


def load_profile() -> dict:
    return json.loads(profile_path().read_text(encoding="utf-8"))


def usage() -> int:
    print("usage: velyx-vm-preview profile | check", file=sys.stderr)
    return 1


def main() -> int:
    if len(sys.argv) < 2:
        return usage()
    command = sys.argv[1]
    profile = load_profile()
    if command == "profile":
        print(json.dumps(profile, ensure_ascii=False, indent=2))
        return 0
    if command == "check":
        result = {
            "profile": profile["profile_id"],
            "shell_primary_session": True,
            "first_boot_required": True,
            "installer_entry": "velyx-installer",
            "recovery_entry": "velyx-recovery",
            "update_entry": "velyx-update",
        }
        print(json.dumps(result, ensure_ascii=False, indent=2))
        return 0
    return usage()


if __name__ == "__main__":
    raise SystemExit(main())
