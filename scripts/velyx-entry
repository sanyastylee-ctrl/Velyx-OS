#!/usr/bin/env python3
import json
import os
import shutil
import subprocess
import sys
from datetime import datetime, timezone
from pathlib import Path
from typing import Any


def now_iso() -> str:
    return datetime.now(timezone.utc).replace(microsecond=0).isoformat().replace("+00:00", "Z")


def load_env_file() -> dict[str, str]:
    env_path = Path(os.environ.get("XDG_CONFIG_HOME", str(Path.home() / ".config"))) / "velyx" / "velyx.env"
    values: dict[str, str] = {}
    if env_path.exists():
        for line in env_path.read_text(encoding="utf-8").splitlines():
            line = line.strip()
            if not line or line.startswith("#") or "=" not in line:
                continue
            key, value = line.split("=", 1)
            values[key.strip()] = value.strip()
    return values


ENV = load_env_file()
ROOT = Path(__file__).resolve().parent.parent
STATE_DIR = Path(os.environ.get("VELYX_STATE_DIR") or ENV.get("VELYX_STATE_DIR") or (Path.home() / ".velyx"))
ENTRY_LOG = STATE_DIR / "entry.log"


def log_event(event: str, status: str, detail: str = "") -> None:
    STATE_DIR.mkdir(parents=True, exist_ok=True)
    with ENTRY_LOG.open("a", encoding="utf-8") as fh:
        fh.write(f"{now_iso()} event={event} status={status} {detail}\n")


def shell_debug_enabled() -> bool:
    return os.environ.get("VELYX_SHELL_DEBUG", "0") == "1" or "--debug-shell" in sys.argv


def log_debug(message: str) -> None:
    if not shell_debug_enabled():
        return
    line = f"{now_iso()} debug {message}"
    STATE_DIR.mkdir(parents=True, exist_ok=True)
    with ENTRY_LOG.open("a", encoding="utf-8") as fh:
        fh.write(line + "\n")
    print(line, file=sys.stderr, flush=True)


def print_json(payload: Any) -> None:
    print(json.dumps(payload, ensure_ascii=False, indent=2))


def tool_path(name: str) -> list[str]:
    tool = shutil.which(name)
    if tool:
        return [tool]
    local = ROOT / "scripts" / name
    if local.exists():
        return [sys.executable, str(local)]
    raise RuntimeError(f"{name} is not available")


def run_tool(name: str, args: list[str], timeout: int = 240) -> dict[str, Any]:
    command = [*tool_path(name), *args]
    log_debug(f"run_tool command={command} timeout={timeout}")
    result = subprocess.run(command, capture_output=True, text=True, timeout=timeout, check=False)
    output = result.stdout.strip()
    payload: dict[str, Any]
    if output.startswith("{"):
        try:
            payload = json.loads(output)
        except Exception:
            payload = {"raw_output": output}
    else:
        payload = {"raw_output": output}
    payload["exit_code"] = result.returncode
    payload["stderr"] = result.stderr.strip()
    return payload


def run_install() -> dict[str, Any]:
    return run_tool("velyx-installer", [])


def run_repair() -> dict[str, Any]:
    return run_tool("velyx-installer", ["--non-interactive", "--action", "repair"])


def run_diagnostics() -> dict[str, Any]:
    return run_tool("velyx-installer", ["--non-interactive", "--action", "diagnostics"])


def run_live() -> dict[str, Any]:
    return run_tool("velyx-live", [], timeout=60)


def shell_command() -> list[str]:
    env_shell = os.environ.get("VELYX_SHELL_BINARY") or ENV.get("VELYX_SHELL_BINARY")
    if env_shell:
        return [env_shell]
    tool = shutil.which("velyx-shell")
    if tool:
        return [tool]
    prefix = Path(
        os.environ.get("VELYX_INSTALL_PREFIX")
        or ENV.get("VELYX_INSTALL_PREFIX")
        or (Path.home() / ".local/share/velyx")
    )
    binary = prefix / "bin" / "velyx-shell"
    return [str(binary)]


def run_shell_session() -> dict[str, Any]:
    log_debug(
        "run_shell_session begin "
        f"cwd={os.getcwd()} home={Path.home()} tty={os.ttyname(0) if os.isatty(0) else 'not-a-tty'}"
    )
    first_boot = run_tool("velyx-firstboot", ["status"], timeout=30)
    completed = bool(first_boot.get("completed", False))
    if not completed:
        run_tool("velyx-firstboot", ["start"], timeout=30)
        log_event("session_route", "pending_first_boot", "path=first_boot")
    else:
        log_event("session_route", "ready", "path=shell")

    command = shell_command()
    env = os.environ.copy()
    env.setdefault("VELYX_PRODUCT_ENTRY", "velyx-entry")
    log_debug(
        "shell command resolved "
        f"command={command} completed={completed} "
        f"graphics_requested={env.get('VELYX_GRAPHICS_MODE_REQUESTED','')} "
        f"graphics_active={env.get('VELYX_GRAPHICS_MODE_ACTIVE','')} "
        f"graphics_fallback={env.get('VELYX_GRAPHICS_FALLBACK_OCCURRED','')} "
        f"graphics_reason={env.get('VELYX_GRAPHICS_FALLBACK_REASON','')} "
        f"qt_qpa={env.get('QT_QPA_PLATFORM','')} "
        f"qt_quick_backend={env.get('QT_QUICK_BACKEND','')} "
        f"qsg_rhi={env.get('QSG_RHI_BACKEND','')} "
        f"qt_xcb_gl_integration={env.get('QT_XCB_GL_INTEGRATION','')} "
        f"libgl_software={env.get('LIBGL_ALWAYS_SOFTWARE','')} "
        f"qml_import={env.get('QML2_IMPORT_PATH','')} "
        f"plugin_path={env.get('QT_PLUGIN_PATH','')} "
        f"dbus={env.get('DBUS_SESSION_BUS_ADDRESS','')}"
    )
    try:
        if shell_debug_enabled():
            log_debug("launching shell with inherited stdout/stderr")
            result = subprocess.run(command, text=True, timeout=120, check=False, env=env)
        else:
            result = subprocess.run(command, capture_output=True, text=True, timeout=120, check=False, env=env)
    except FileNotFoundError:
        return {
            "completed": completed,
            "first_boot_required": not completed,
            "shell_command": command,
            "exit_code": 1,
            "stderr": "Velyx Shell is not installed yet.",
        }
    payload = {
        "completed": completed,
        "first_boot_required": not completed,
        "shell_command": command,
        "exit_code": result.returncode,
        "stdout": getattr(result, "stdout", "") or "",
        "stderr": getattr(result, "stderr", "") or "",
    }
    log_debug(
        "shell exited "
        f"exit_code={payload['exit_code']} "
        f"stdout_len={len(payload['stdout'])} stderr_len={len(payload['stderr'])}"
    )
    return payload


def interactive() -> dict[str, Any]:
    print("Velyx OS")
    print("========")
    print("1. Install Velyx")
    print("2. Try Velyx (Live / Preview)")
    print("3. Repair / Diagnostics")
    choice = input("Choose 1, 2, or 3 [1]: ").strip() or "1"
    if choice == "2":
        return {"action": "live"}
    if choice == "3":
        sub = input("Type 'repair' or 'diagnostics' [diagnostics]: ").strip().lower() or "diagnostics"
        return {"action": "repair" if sub == "repair" else "diagnostics"}
    return {"action": "install"}


def noninteractive(args: list[str]) -> dict[str, str]:
    action = "install"
    if "--session" in args:
        return {"action": "session"}
    if "--action" in args:
        index = args.index("--action")
        if index + 1 >= len(args):
            raise RuntimeError("Missing action value")
        action = args[index + 1]
    return {"action": action}


def main() -> int:
    try:
        session_mode = "--session" in sys.argv
        if shell_debug_enabled():
            log_debug(f"entry argv={sys.argv[1:]} env_file_keys={sorted(ENV.keys())}")
        payload = interactive() if "--non-interactive" not in sys.argv and not session_mode else noninteractive(sys.argv[1:])
        action = payload["action"]
        log_event("entry_begin", "started", f"action={action}")
        if action == "install":
            result = run_install()
        elif action == "session":
            result = run_shell_session()
        elif action == "live":
            result = run_live()
        elif action == "repair":
            result = run_repair()
        elif action == "diagnostics":
            result = run_diagnostics()
        else:
            raise RuntimeError(f"Unsupported action: {action}")
        status = "ok" if result.get("exit_code", 1) == 0 else "failed"
        log_event("entry_complete", status, f"action={action}")
        print_json(
            {
                "status": status,
                "summary": {
                "install": "Velyx Installer finished.",
                "session": "Velyx session entry finished.",
                "live": "Velyx Live path completed.",
                "repair": "Velyx repair path finished.",
                "diagnostics": "Velyx diagnostics are ready.",
            }.get(action, "Velyx entry finished."),
            "entry_action": action,
                "result": result,
                "next_step": {
                    "install": "Continue into Velyx First Boot, then Velyx Shell.",
                    "session": "Velyx Entry routed into First Boot or directly into Velyx Shell.",
                    "live": "You are in Velyx Live preview mode.",
                    "repair": "Return to Velyx Entry or continue with Velyx Recovery.",
                    "diagnostics": "Review diagnostics or continue into install/repair.",
                }.get(action, "Continue with Velyx."),
            }
        )
        return 0 if status == "ok" else 1
    except Exception as exc:
        log_event("entry_failed", "failed", str(exc))
        print(str(exc), file=sys.stderr)
        return 1


if __name__ == "__main__":
    raise SystemExit(main())
