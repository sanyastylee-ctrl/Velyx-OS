#!/usr/bin/env python3
import subprocess
import sys
from pathlib import Path


ROOT = Path(__file__).resolve().parent.parent


def main() -> int:
    target = ROOT / "scripts" / "velyx-release-preview"
    if not target.exists():
      print("velyx-release-preview is not available", file=sys.stderr)
      return 1
    result = subprocess.run([sys.executable, str(target), "validate", *sys.argv[1:]], check=False)
    return result.returncode


if __name__ == "__main__":
    raise SystemExit(main())
