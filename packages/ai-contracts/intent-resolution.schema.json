{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IntentResolution",
  "type": "object",
  "required": ["intent_id", "intent_kind", "confidence", "requires_clarification", "proposed_tools"],
  "properties": {
    "intent_id": { "type": "string" },
    "intent_kind": {
      "type": "string",
      "enum": ["LaunchApp", "SearchFiles", "ReadSetting", "ChangeSetting", "InspectPermissions", "UpdatePermissions", "DiagnosticsExplain", "SecurityExplain", "Unknown"]
    },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "requires_clarification": { "type": "boolean" },
    "clarification_question": { "type": ["string", "null"] },
    "proposed_tools": { "type": "array", "items": { "type": "string" } }
  }
}
